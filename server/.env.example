# Copy this file, rename the copy to  .env  and fill in your values.
# NEVER commit the real .env to GitHub (it is already in .gitignore).

# Format: postgresql://USERNAME:PASSWORD@localhost:5432/DATABASE_NAME
# USERNAME is "postgres" (the default), PASSWORD is what you set during PostgreSQL install.
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD_HERE@localhost:5432/hackathon?schema=public"

# Any long random string. Used to sign login tokens.
JWT_SECRET="change-this-to-any-long-random-string-98431"

# Where the backend runs
PORT=5000

# Where the frontend runs (needed for CORS + Socket.io)
CLIENT_URL="http://localhost:5173"

# AI keys (fill the ones you have)
NVIDIA_API_KEY=""
HUGGINGFACE_API_KEY=""
OPENAI_API_KEY=""
