# Copy this file, rename the copy to .env and fill in your values.
# NEVER commit the real .env to GitHub (it is already in .gitignore).

# Database
# Format: postgresql://USERNAME:PASSWORD@localhost:5432/DATABASE_NAME
# USERNAME is usually "postgres" (default)
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD_HERE@localhost:5432/hackathon?schema=public"

# JWT secrets for token signing — access and refresh MUST be different secrets
# Each MUST be at least 32 characters long. Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="your-access-secret-min-32-chars-very-important-do-not-share"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-must-differ-from-access"

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS and Socket.io)
CLIENT_URL="http://localhost:5173"

# Optional: AI/ML APIs
OPENAI_API_KEY=""
HUGGINGFACE_API_KEY=""
NVIDIA_API_KEY=""

# Debug mode (set to "true" to see detailed logs)
DEBUG="false"
