// This file describes your database tables.
// After ANY change here, run:  npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String @db.VarChar(255)
  email    String @unique @db.VarChar(255)
  password String // bcrypt hash only, NEVER plain text

  // Timestamps are REQUIRED for professional database design
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  // Soft delete capability for data retention
  deletedAt DateTime? @db.Timestamp(6)

  // Future relations will go here
  // posts Post[]
  // comments Comment[]
  exampleTasks ExampleTask[]

  // Indexes speed up queries - judges notice this!
  @@index([email])
  @@index([createdAt])
  @@index([deletedAt])
}

// TOMORROW: Replace this with your actual problem model
// This is just an example showing judges what you understand
model ExampleTask {
  id          String  @id @default(uuid())
  title       String  @db.VarChar(255)
  description String? @db.Text

  // Status enum - judges love type safety
  status   TaskStatus @default(PENDING)
  priority Int        @default(0)

  // Foreign key to User
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@unique([userId, title]) // Enforce uniqueness at DB level
  // Indexes for common queries
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
