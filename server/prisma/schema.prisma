// This file describes your database tables.
// After ANY change here, run:  npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // stored as bcrypt hash, never plain text
  createdAt DateTime @default(now())

  // TOMORROW: add relations to your problem-specific models here
  // e.g.  posts Post[]
}

